# Azure SQL Database Environment Configuration Template
# Copy this file to .env.azure and fill in your Azure SQL connection details
# DO NOT commit this file with real credentials!

# =============================================================================
# DATABASE CONFIGURATION (Required)
# =============================================================================

# Application User Connection (Limited permissions for runtime)
# Format: mssql+aioodbc://username:password@server.database.windows.net:1433/dbname?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
IDENTITY_DATABASE_URL=mssql+aioodbc://app_user:YOUR_APP_USER_PASSWORD@YOUR_SERVER.database.windows.net:1433/YOUR_DATABASE_NAME?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# Migration Admin Connection (Full permissions for schema changes)
IDENTITY_DATABASE_MIGRATION_URL=mssql+aioodbc://migration_admin:YOUR_MIGRATION_ADMIN_PASSWORD@YOUR_SERVER.database.windows.net:1433/YOUR_DATABASE_NAME?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# Example (DO NOT USE IN PRODUCTION):
# IDENTITY_DATABASE_URL=mssql+aioodbc://app_user:MyAppPass123!@microserviceslab-sql.database.windows.net:1433/identityservice-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
# IDENTITY_DATABASE_MIGRATION_URL=mssql+aioodbc://migration_admin:MyAdminPass123!@microserviceslab-sql.database.windows.net:1433/identityservice-db?driver=ODBC+Driver+18+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no

# =============================================================================
# AUTHENTICATION CONFIGURATION (Required)
# =============================================================================

# Secret key for JWT token signing (minimum 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_TOKEN_KEY=your-secret-key-at-least-32-characters-long-replace-this

# JWT algorithm (typically HS256)
AUTH_ALGORITHM=HS256

# Token expiration time in minutes
TOKEN_TIME_DELTA_IN_MINUTES=60

# Default role assigned to new users
DEFAULT_USER_ROLE=User

# Token endpoint path
TOKEN_URL=/token

# Service UUID for RBAC scoping and tracing
# Generate with: python -c "import uuid; print(uuid.uuid4())"
SERVICE_ID=00000000-0000-0000-0000-000000000001

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Maximum failed password attempts before account lockout
MAX_FAILED_PASSWORD_ATTEMPTS=3

# Account lockout duration in minutes after max failed attempts
LOCKOUT_DURATION_IN_MINUTES=60

# =============================================================================
# CORS CONFIGURATION (Required for frontend)
# =============================================================================

# Comma-separated list of allowed origins (or * for all)
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
CORS_ALLOW_ORIGINS=*

# =============================================================================
# LOGGING CONFIGURATION (Optional)
# =============================================================================

# Application log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Structured JSON logging with rich context
STRUCTURED_LOGGING_ENABLED=true

# =============================================================================
# LOKI LOGGING CONFIGURATION (Optional - Centralized Logging)
# =============================================================================

# Enable Loki centralized logging
LOKI_ENABLED=false

# Loki push endpoint URL
LOKI_URL=http://localhost:3100

# Loki labels (comma-separated key=value pairs)
LOKI_LABELS=service=identity-service,environment=production

# Loki batch push interval in seconds
LOKI_BATCH_INTERVAL=60

# Loki push request timeout in seconds
LOKI_TIMEOUT=10.0

# Minimum log level to send to Loki
MIN_LOG_LEVEL_FOR_LOKI=INFO

# =============================================================================
# METRICS CONFIGURATION (Optional - Prometheus)
# =============================================================================

# Enable metrics collection
METRICS_ENABLED=true

# Metrics endpoint path
METRICS_ENDPOINT=/metrics

# Enable specific metric types
ENABLE_HTTP_METRICS=true
ENABLE_BUSINESS_METRICS=true
ENABLE_DATABASE_METRICS=true

# Metrics collection interval in seconds
METRICS_COLLECTION_INTERVAL=60

# =============================================================================
# TRACING CONFIGURATION (Optional - Tempo/OpenTelemetry)
# =============================================================================

# Enable distributed tracing with OpenTelemetry
TRACING_ENABLED=false

# Tempo OTLP gRPC endpoint URL
TEMPO_ENDPOINT=http://localhost:4317

# Trace sampling rate (0.0 to 1.0, where 1.0 means 100%)
TRACE_SAMPLE_RATE=1.0

# Enable console export of traces for debugging
ENABLE_TRACE_CONSOLE_EXPORT=false

# =============================================================================
# NOTES
# =============================================================================

# 1. Connection String Requirements:
#    - Encrypt=yes is REQUIRED for Azure SQL
#    - TrustServerCertificate=no validates SSL certificate
#    - LongAsMax=Yes is automatically added by alembic env.py

# 2. User Permissions:
#    - app_user: db_datareader, db_datawriter, EXECUTE
#    - migration_admin: db_owner (for schema changes)

# 3. Security Best Practices:
#    - Store secrets in Azure Key Vault in production
#    - Use Managed Identity for Azure services
#    - Rotate passwords regularly
#    - Never commit this file with real credentials

# 4. Generate Strong Secrets:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#    python -c "import uuid; print(uuid.uuid4())"

# 5. Test Connection:
#    After configuring, test with:
#    .\run-migration.ps1 -Command current
